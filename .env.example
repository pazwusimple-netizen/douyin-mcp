# Copy this file to `.env.local` for local-only secrets.
# `.env.local` is ignored by Git and loaded automatically by the project.

# ====== Douyin login / cookie ======
# DOUYIN_COOKIE=
# DOUYIN_COOKIE_PATH=/Users/yourname/.config/douyinmcp/cookies.txt

# ====== ASR ======
ASR_PROVIDER=volcengine
VOLCENGINE_APP_ID=your_app_id
VOLCENGINE_ACCESS_TOKEN=your_access_token
VOLCENGINE_MODEL=bigmodel
VOLCENGINE_RESOURCE_ID=volc.bigasr.auc_turbo
VOLCENGINE_API_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash

# ====== OCR ======
# OCR_PROVIDER=rapidocr

# ====== Transcript output ======
# DOUYIN_AUTO_SAVE_TRANSCRIPTS=true
# DOUYIN_TRANSCRIPT_DIR=/Users/yourname/.local/share/douyinmcp/transcripts

# ====== Long audio chunking ======
# MAX_AUDIO_DURATION=7200
# AUDIO_CHUNK_THRESHOLD=600
# AUDIO_CHUNK_DURATION=480
# AUDIO_CHUNK_MAX_FILE_SIZE_MB=45
