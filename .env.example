# 环境变量参考
# 以下列出了项目用到的所有环境变量。
# 通过 MCP --env 或 ~/.zshrc 配置即可，不需要创建 .env 文件。

# ====== ASR（语音转文字，其他功能不需要配） ======
# ASR_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=sk-你的Key

# ====== 可选 ======
# DOUYIN_DOWNLOAD_DIR=~/Downloads/douyinmcp
# DOUYIN_TRANSCRIPT_DIR=~/Downloads/douyinmcp/transcripts
# DOUYIN_AUTO_SAVE_TRANSCRIPTS=true
# DOUYIN_COOKIE_PATH=~/.config/douyinmcp/cookies.txt
